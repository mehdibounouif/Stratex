# Stratex Environment Configuration

# 1. Alpaca Broker API (Paper Trading)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# 2. Data Sources & AI
OPENAI_API_KEY=sk-your_openai_key_here  # Optional: for AI analysis
ALPHA_VANTAGE_API_KEY=your_key_here       # Optional: for fundamentals

# 3. System Settings
ENVIRONMENT=development  # development | production
DEBUG=True
DATABASE_URL=sqlite:///data/trading_data.db
YFINANCE_LOG_LEVEL=WARNING
REQUESTS_LOG_LEVEL=WARNING

# 4. Alert Notifications (Feature 1)
ENABLE_TELEGRAM_ALERTS=false
TELEGRAM_BOT_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ
TELEGRAM_CHAT_ID=123456789

ENABLE_EMAIL_ALERTS=false
ALERT_EMAIL_SENDER=your-app-email@gmail.com
ALERT_EMAIL_PASSWORD=your-app-password
ALERT_EMAIL_RECIPIENT=your-personal-email@example.com

# 5. REST API Security (Feature 3)
API_SECRET_KEY=change-me-in-production
API_HOST=0.0.0.0
API_PORT=8000
